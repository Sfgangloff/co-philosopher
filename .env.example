# Copy to .env and fill in. .env is gitignored.

# LLM backend for `cophilo extract` and `cophilo biblio synthesize`.
# Default ("cli") shells out to the local Claude Code CLI and needs NO API
# key. Set to "api" to use the Anthropic SDK (then ANTHROPIC_API_KEY below
# is required).
# COPHILO_LLM_BACKEND=cli
# COPHILO_CLAUDE_CLI=claude

# Anthropic API key — ONLY needed when COPHILO_LLM_BACKEND=api.
ANTHROPIC_API_KEY=

# OpenAI API key for embeddings (text-embedding-3-large).
# Required for `cophilo taxonomy recluster` and semantic search.
OPENAI_API_KEY=

# `cophilo biblio search` needs no key (PhilArchive RSS is public).

# Optional overrides. Defaults shown.
# COPHILO_DATA_DIR=./data
# COPHILO_DB_PATH=./data/db/cophilo.sqlite
# COPHILO_DEFAULT_LANGUAGE=en
# COPHILO_CLAUDE_MODEL_ROUTINE=claude-sonnet-4-6
# COPHILO_CLAUDE_MODEL_HARD=claude-opus-4-7
# COPHILO_EMBEDDING_MODEL=text-embedding-3-large
# COPHILO_PHILARCHIVE_BASE_URL=https://philarchive.org
# COPHILO_HTTP_USER_AGENT=cophilo/0.1 (+https://github.com/Sfgangloff/co-philosopher)
