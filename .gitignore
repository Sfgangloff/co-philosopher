# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.python-version

# Build / dist
build/
dist/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# Env
.env
.env.local

# Data policy: anything personal or built from your notes/articles is NOT
# tracked in this (tool) repo — it lives only in the private backup repo
# created by `cophilo backup`. Keep this list and backup.backup_paths() in
# sync. `data/journals.yaml` is the one exception: a curated source list,
# tracked here, the basis of the (gitignored, regenerable) memory index.
# NOTE: .gitignore does not support inline `#` comments — a `#` only starts a
# comment at the start of a line. Keep these patterns comment-free.
data/corpus/
data/normalized/
data/rendered/
data/proposals/
data/db/*.sqlite
data/db/*.sqlite-*

# Stray scratch notes at repo root (personal, notes-derived — not tool code)
example.txt

# Editor
.vscode/
.idea/
*.swp
.DS_Store
