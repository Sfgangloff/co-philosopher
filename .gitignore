# Data policy: anything personal or built from your notes/articles is NOT
# tracked in this (tool) repo — it lives only in the private backup repo
# created by `cophilo backup`. Keep this list and backup.backup_paths() in
# sync. `data/journals.yaml` is the one exception: a curated source list,
# tracked here, the basis of the (gitignored, regenerable) memory index.
data/corpus/         # notes, articles, drafts
data/normalized/     # normalized text built from the corpus
data/rendered/       # annotated md/html built from the corpus
data/proposals/      # article proposals built from your notes
data/db/*.sqlite     # extraction DB + memory index
data/db/*.sqlite-*   # sqlite WAL/SHM sidecars

# Editor
.vscode/
.idea/
*.swp
.DS_Store
